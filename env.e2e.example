# KBIT E2E test credentials — copy to .env.e2e.local locally if needed.
# Never commit real credentials.

# Required to run the full admin-to-member workflow test.
E2E_ADMIN_EMAIL=le.ntmkh@gmail.com
E2E_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_TEST_PASSWORD
E2E_MEMBER_PASSWORD=REPLACE_WITH_TEMP_MEMBER_PASSWORD_FOR_TEST_CREATED_ACCOUNT

# Optional overrides. Defaults are local preview servers started by Playwright.
E2E_PUBLIC_BASE_URL=http://127.0.0.1:4173
E2E_ADMIN_BASE_URL=http://127.0.0.1:4174

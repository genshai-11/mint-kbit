{
  "name": "kbit-web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "optimize-images": "node scripts/optimize-images.mjs",
    "analyze": "vite build --mode analyze",
    "export-translations": "node scripts/export-missing-translations.mjs",
    "migrate-sanity": "node --env-file=.env.local scripts/migrate-to-sanity.mjs",
    "migrate-membership:cli": "cd studio && npx sanity exec scripts/migrate-membership-with-user-token.cjs --with-user-token",
    "migrate-event-library:cli": "cd studio && npx sanity exec scripts/migrate-event-library-with-user-token.cjs --with-user-token",
    "migrate-event-program:cli": "cd studio && npx sanity exec scripts/migrate-event-program-with-user-token.cjs --with-user-token",
    "studio": "cd studio && npm run dev",
    "export-sanity": "node scripts/export-sanity-ndjson.mjs",
    "studio:build": "cd studio && npm run build",
    "sanity:smoke": "node --env-file=.env.local scripts/sanity-smoke.mjs",
    "studio:deploy": "cd studio && npm run deploy",
    "studio:deploy-graphql": "cd studio && npm run deploy-graphql",
    "admin:dev": "cd admin && npm run dev",
    "admin:build": "cd admin && npm run build",
    "admin:preview": "cd admin && npm run preview"
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "@sanity/client": "^6.28.2",
    "@sanity/image-url": "^1.1.0",
    "@supabase/supabase-js": "^2.108.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "rollup-plugin-visualizer": "^5.14.0",
    "sharp": "^0.34.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vite-imagetools": "^7.0.5"
  }
}
